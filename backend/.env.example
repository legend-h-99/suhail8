# Application
NODE_ENV=development
PORT=4000
APP_NAME="نظام إدارة كلية الاتصالات والمعلومات بالرياض"
APP_URL=http://localhost:4000

# Database (Postgres) — لكل tenant قاعدة بيانات / schema منفصلة عبر TENANT_DB_URL_TEMPLATE
DATABASE_URL=postgresql://erp:erp_password@localhost:5432/tcc_erp?schema=public

# Tenancy
TENANCY_MODE=schema_per_tenant   # schema_per_tenant | row_level
DEFAULT_TENANT_SLUG=cci-riyadh

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=2592000

# Argon2
ARGON_MEMORY=19456
ARGON_TIME=2
ARGON_PARALLELISM=1

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
