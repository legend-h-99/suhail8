  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("data_processing_jobs")
}

enum ProcessingType {
  ETL
  VALIDATION
  CLEANING
  AGGREGATION
  KPI_COMPUTE
  AI_INDEXING
