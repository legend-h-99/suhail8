}

enum TeamStatus {
  PROPOSED
  ACTIVE
  DISBANDED
}

model QualityTeamTask {
  id          String   @id @default(cuid())
  teamId      String
  team        QualityTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title       String
  assigneeEmpId String?
  dueAt       DateTime?
  status      TaskStatus @default(TODO)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId, status])
  @@map("quality_team_tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Accreditation {
  id              String   @id @default(cuid())
  tenantId        String
  standardCode    String
  nameAr          String
  description     String?
  cycle           String
  status          AccreditationStatus @default(NOT_STARTED)
  responsibleEmpId String?
  dueDate         DateTime?
  weight          Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evidence        AccreditationEvidence[]

  @@unique([tenantId, standardCode, cycle])
  @@index([tenantId, status])
