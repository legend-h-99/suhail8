  updatedAt     DateTime @updatedAt

  @@unique([tenantId, departmentId, fiscalYear, scope])
  @@map("training_plans")
}

enum TrainingPlanScope {
  SEASONAL
  YEARLY
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

model SupervisionVisit {
  id           String   @id @default(cuid())
