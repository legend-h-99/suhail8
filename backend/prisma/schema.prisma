// =====================================================================
// 14d. TASKS / PROJECTS / BOARDS — نظام إدارة المهام والمشاريع
// =====================================================================

model Task {
  id            String   @id @default(cuid())
  tenantId      String
  title         String
  description   String?  @db.Text
  status        TaskState @default(NEW)
  priority      TaskPriority @default(NORMAL)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  assigneeId    String?
  createdById   String
  departmentId  String?
  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parentTaskId  String?
  parent        Task?    @relation("TaskSubtasks", fields: [parentTaskId], references: [id])
  subtasks      Task[]   @relation("TaskSubtasks")
  tags          String[]
  attachments   Json?    // [{ name, url, size }]
  kpiCode       String?  // ربط اختياري بـ KPI
  reportId      String?  // ربط اختياري بتقرير
  comments      TaskComment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([assigneeId, status])
  @@map("tasks")
}

enum TaskState {
  NEW
  IN_PROGRESS
  PENDING_APPROVAL
  DONE
  OVERDUE
  REJECTED
  ARCHIVED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("task_comments")
}

model Project {
  id           String   @id @default(cuid())
  tenantId     String
  code         String
  nameAr       String
  description  String?  @db.Text
  type         ProjectType @default(OPERATIONAL)
  ownerId      String
  status       ProjectStatus @default(PLANNING)
  startDate    DateTime
  targetEndDate DateTime?
  actualEndDate DateTime?
  progress     Int      @default(0)  // 0-100
  budget       Decimal? @db.Decimal(15, 2)
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      ProjectMember[]
  milestones   Milestone[]
  tasks        Task[]
  risks        ProjectRisk[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("projects")
}

enum ProjectType {
  OPERATIONAL
  STRATEGIC
  QUALITY
  TECHNICAL
  FINANCIAL
  TRAINING
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("MEMBER")  // OWNER, MANAGER, MEMBER, OBSERVER
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_members")
}

model Milestone {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nameAr     String
  dueDate    DateTime
  completedAt DateTime?
  order      Int      @default(0)

  @@index([projectId])
  @@map("milestones")
}

model ProjectRisk {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  likelihood  Int      // 1-5
  impact      Int      // 1-5
  mitigation  String?
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  @@map("project_risks")
}

model Board {
  id           String   @id @default(cuid())
  tenantId     String
  nameAr       String
  type         BoardType @default(TASK)
  scope        String   // 'unit:DEPT_TRAINING' or 'project:abc' or 'global'
  ownerId      String
  createdAt    DateTime @default(now())

  columns      BoardColumn[]

  @@index([tenantId])
  @@map("boards")
}

enum BoardType {
  TASK
  PROJECT
  APPROVAL
  QUALITY
  RISK
  UNIT
  AI_SUGGESTIONS
}

model BoardColumn {
  id        String   @id @default(cuid())
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  nameAr    String
  color     String?  // hex color
  order     Int      @default(0)

  cards     BoardCard[]

  @@map("board_columns")
}

model BoardCard {
  id          String   @id @default(cuid())
  columnId    String
  column      BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  title       String
  description String?
  taskId      String?  // ربط اختياري بمهمة
  assigneeId  String?
  dueDate     DateTime?
  order       Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([columnId, order])
  @@map("board_cards")
}

// =====================================================================
// 14e. AI + CHATBOT
