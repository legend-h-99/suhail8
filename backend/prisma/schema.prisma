model TrainingPlan {
  id            String   @id @default(cuid())
  tenantId      String
  departmentId  String
  department    Department @relation("DeptTrainingPlans", fields: [departmentId], references: [id], onDelete: Cascade)
  fiscalYear    String   // 1446 / 2025-2026
  scope         TrainingPlanScope @default(YEARLY)
  goals         Json     // [{ id, ar, kpiCode, target }]
  activities    Json     // [{ id, ar, ownerEmpId, startDate, endDate, status }]
  status        PlanStatus @default(DRAFT)
  createdById   String
  approvedAt    DateTime?
  workflowInstanceId String? @unique
  workflowInstance WorkflowInstance? @relation("TrainingPlanWF", fields: [workflowInstanceId], references: [id])
