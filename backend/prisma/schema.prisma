  @@unique([sectionId, date])
  @@index([trainerId, date])
  @@map("class_sessions")
}

model TrainerReport {
  id        String   @id @default(cuid())
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
