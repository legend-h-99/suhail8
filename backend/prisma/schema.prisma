  @@map("trainer_notes")
}

enum NoteVisibility {
  PRIVATE       // المدرب فقط
  TEAM          // كل مدربي القسم
  ADMINISTRATIVE  // الإدارة فقط
}

model ClassSession {
  id              String   @id @default(cuid())
  trainerId       String
  trainer         Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
