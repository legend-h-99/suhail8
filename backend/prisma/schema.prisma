  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMESTER
  YEARLY
}

model KpiMeasurement {
  id        String   @id @default(cuid())
  kpiId     String
  kpi       Kpi      @relation(fields: [kpiId], references: [id], onDelete: Cascade)
