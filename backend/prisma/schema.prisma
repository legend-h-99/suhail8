// =====================================================================
// 16. WORKFLOW ENGINE — محرك سير الإجراءات والاعتمادات
// =====================================================================

model WorkflowDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String   // LEAVE_REQUEST, PR_APPROVAL, MEETING_MINUTES, ...
  nameAr      String
  description String?
  entityType  String   // 'leave', 'purchase_request', 'meeting', ...
  steps       Json     // [{ key, nameAr, role, scope, condition, sla, parallel }]
  active      Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instances   WorkflowInstance[]

  @@unique([tenantId, code, version])
  @@map("workflow_definitions")
}

model WorkflowInstance {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  definitionId String
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  entityType   String
  entityId     String
  initiatedById String
  initiatedBy  User     @relation("InitiatedBy", fields: [initiatedById], references: [id])
  status       WorkflowStatus @default(IN_PROGRESS)
  currentStep  String?
  data         Json?
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  metadata     Json?

  steps        ApprovalStep[]
  leave        Leave?
  evaluation   Evaluation?
  meeting      Meeting?
  purchaseRequest PurchaseRequest?
  graduation   Graduation?
  trainingPlan TrainingPlan? @relation("TrainingPlanWF")

  @@index([entityType, entityId])
  @@index([tenantId, status])
  @@map("workflow_instances")
}

enum WorkflowStatus {
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

model ApprovalStep {
  id            String   @id @default(cuid())
  instanceId    String
  instance      WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepKey       String
  stepNameAr    String
  requiredRole  String?
  scopeType     String?
  scopeId       String?
  status        StepStatus @default(PENDING)
  actedById     String?
  actedBy       User?    @relation("ActedBy", fields: [actedById], references: [id])
  decision      StepDecision?
  comment       String?
  dueAt         DateTime?
  actedAt       DateTime?
  order         Int

  @@index([instanceId, order])
  @@map("approval_steps")
}

enum StepStatus {
  PENDING
  ACTIVE
  APPROVED
  REJECTED
  SKIPPED
  EXPIRED
}

enum StepDecision {
  APPROVE
  REJECT
  REQUEST_CHANGES
  DELEGATE
}

// =====================================================================
// 17. AUDIT, NOTIFICATIONS, ATTACHMENTS
// =====================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // CREATE, UPDATE, DELETE, LOGIN, APPROVE, ...
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotifChannel @default(IN_APP)
  type       String   // workflow.action_required, leave.approved, ...
  titleAr    String
  bodyAr     String?
  link       String?
  data       Json?
  readAt     DateTime?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

enum NotifChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model Attachment {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerType    String   // 'leave', 'meeting', 'purchase_request', ...
  ownerId      String
  fileName     String
  mimeType     String
  size         Int
  storageKey   String
  url          String?
  uploadedById String
  uploadedBy   User     @relation("UploadedBy", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  leave            Leave?            @relation(fields: [leaveId], references: [id])
  leaveId          String?
  meeting          Meeting?          @relation(fields: [meetingId], references: [id])
  meetingId        String?
  purchaseRequest  PurchaseRequest?  @relation(fields: [prId], references: [id])
  prId             String?
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  invoiceId        String?
  ticket           Ticket?           @relation(fields: [ticketId], references: [id])
  ticketId         String?
  coopPlacement    CoopPlacement?    @relation(fields: [coopPlacementId], references: [id])
  coopPlacementId  String?
  securityIncident SecurityIncident? @relation(fields: [securityIncidentId], references: [id])
  securityIncidentId String?

  @@index([ownerType, ownerId])
  @@map("attachments")
}
