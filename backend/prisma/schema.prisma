// =====================================================================
// Prisma Schema — نظام ERP لإدارة الكليات التقنية
// كلية الاتصالات والمعلومات بالرياض (CCI-Riyadh)
//
// نموذج Multi-tenant:
//   - tenant_id موجود في كل جدول قابل للعزل
//   - عند تفعيل TENANCY_MODE=schema_per_tenant يتم إنشاء schema منفصل لكل tenant
//   - في وضع row_level، الـ tenant interceptor يحقن tenantId تلقائياً
//
// التغطية:
//   1. Tenancy & Identity (Tenant, User, Session)
//   2. RBAC (Role, Permission, RolePermission, UserRole)
//   3. Org Structure (Department, Position, Assignment)
//   4. HR (Employee, Leave, Attendance, Contract)
//   5. Council (Council, Meeting, Decision, Vote)
//   6. Finance (Budget, PurchaseRequest, Invoice, Approval)
//   7. Trainees (Trainee, Enrollment, AcademicRecord)
//   8. Trainers (Trainer, TeachingLoad, Evaluation)
//   9. Academic (Program, Course, Section, Schedule, Attendance)
//   10. LMS (LmsCourse, ExamBank, Question, Submission)
//   11. IT Helpdesk (Ticket, Asset, Backup)
//   12. Quality (Kpi, KpiMeasurement, Survey, Risk)
//   13. Community Center (Course, Registration, Payment, Certificate)
//   14. Research (ResearchProject, Innovation, Funding)
//   15. General Services (MaintenanceRequest, SecurityIncident, MedicalVisit)
//   16. Workflow Engine (WorkflowDefinition, WorkflowInstance, ApprovalStep)
//   17. Audit & Notifications
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// 1. TENANCY & IDENTITY
// =====================================================================

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String?
  type        TenantType @default(COLLEGE)
  parentId    String?
  parent      Tenant?  @relation("TenantHierarchy", fields: [parentId], references: [id])
  children    Tenant[] @relation("TenantHierarchy")
  status      TenantStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  departments   Department[]
  roles         Role[]
  councils      Council[]
  employees     Employee[]
  trainees      Trainee[]
  trainers      Trainer[]
  programs      Program[]
  courses       Course[]
  budgets       Budget[]
  workflowDefs  WorkflowDefinition[]
  workflowInsts WorkflowInstance[]
  auditLogs     AuditLog[]
  notifications Notification[]
  attachments   Attachment[]
  tickets       Ticket[]
  assets        Asset[]
  kpis          Kpi[]
  surveys       Survey[]
  risks         Risk[]
  ccCourses     CommunityCourse[]
  research      ResearchProject[]
  maintenance   MaintenanceRequest[]
  securityInc   SecurityIncident[]
  medicalVisits MedicalVisit[]
  qualityImprovementPlans QualityImprovementPlan[] @relation("TenantQIP")

  @@map("tenants")
}

enum TenantType {
  COLLEGE        // كلية رئيسية
  BRANCH         // فرع
  INSTITUTE      // معهد تابع
  PRISON_INSTITUTE  // معهد سجن
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email         String
  username      String?
  passwordHash  String
  fullNameAr    String
  fullNameEn    String?
  nationalId    String?
  phone         String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  userRoles      UserRole[]
  employeeProfile Employee?
  traineeProfile  Trainee?
  trainerProfile  Trainer?
  uploadedFiles   Attachment[] @relation("UploadedBy")
  startedFlows    WorkflowInstance[] @relation("InitiatedBy")
  approvalsActed  ApprovalStep[] @relation("ActedBy")
  auditLogs       AuditLog[]
  notifications   Notification[]
  ticketsCreated  Ticket[] @relation("TicketCreator")
  ticketsAssigned Ticket[] @relation("TicketAssignee")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_VERIFICATION
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent       String?
  ip              String?
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// =====================================================================
// 2. RBAC
// =====================================================================

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String   // e.g., DEAN, VICE_DEAN, DEPT_HEAD, COORDINATOR, TRAINER, EMPLOYEE, TRAINEE, AUDITOR
  nameAr      String
  nameEn      String?
  description String?
  scope       RoleScope @default(TENANT)
  systemRole  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("roles")
}

enum RoleScope {
  GLOBAL          // super admin
  TENANT          // على مستوى الكلية
  DEPARTMENT      // على مستوى القسم
  UNIT            // وحدة محددة
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique  // e.g., council.meeting.create, finance.purchase.approve
  module      String   // e.g., council, finance, hr
  action      String   // e.g., create, read, update, delete, approve
  resource    String   // e.g., meeting, purchase, leave
  nameAr      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  conditions   Json?      // ABAC-style conditions (department-scoped, amount-limit, etc.)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeType    String?  // 'department' | 'unit' | null
  scopeId      String?  // ID of the scoped entity
  validFrom    DateTime @default(now())
  validUntil   DateTime?
  assignedById String?
  createdAt    DateTime @default(now())

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// =====================================================================
// 3. ORG STRUCTURE
// =====================================================================

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String   // CCI-DEAN, CCI-VICE-TRAINEES, ...
  nameAr      String
  nameEn      String?
  type        DepartmentType
  parentId    String?
  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  managerId   String?      // current manager (Employee)
  costCenter  String?
  status      DepartmentStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  positions   Position[]
  assignments Assignment[]
  employees   Employee[]   @relation("EmployeeDepartment")
  managedBy   Employee?    @relation("DepartmentManager", fields: [managerId], references: [id])
  budgets     Budget[]
  meetings    Meeting[]
  purchaseReqs PurchaseRequest[]
  courses     Course[]
  trainingPlans     TrainingPlan[]      @relation("DeptTrainingPlans")
  supervisionVisits SupervisionVisit[]  @relation("DeptSupervisionVisits")
  curriculumReviews CurriculumReview[]  @relation("DeptCurriculumReviews")

  @@unique([tenantId, code])
  @@index([tenantId, parentId])
  @@map("departments")
}

enum DepartmentType {
  COUNCIL              // مجلس المنشأة
  COUNCIL_SECRETARIAT  // أمانة المجلس
  DEANSHIP             // العمادة
  VICE_DEANSHIP        // وكالة (مدربين/متدربين/جودة)
  INSTITUTE_MGMT       // إدارة المعهد
  SECRETARIAT          // السكرتارية
  MONITORING_UNIT      // وحدة الرقابة
  COMMUNICATION_UNIT   // وحدة الاتصال المؤسسي
  IT_UNIT              // وحدة تقنية المعلومات
  RESEARCH_CENTER      // مركز البحث والابتكار
  COMMUNITY_CENTER     // مركز خدمة المجتمع
  TRAINING_DEPT        // قسم تدريبي
  ELEARNING_DEPT       // قسم التدرب الإلكتروني
  CURRICULUM_UNIT      // وحدة المناهج والإشراف
  ADMISSION_DEPT       // قسم القبول والتسجيل
  GUIDANCE_UNIT        // وحدة الخدمات الإرشادية
  ACTIVITIES_UNIT      // وحدة الأنشطة
  COOP_TRAINING_UNIT   // وحدة التدريب التعاوني
  JOB_COORD_DEPT       // قسم التنسيق الوظيفي
  FINANCE_DEPT         // قسم الشؤون المالية
  HR_DEPT              // قسم الشؤون الإدارية
  GENERAL_SERVICES     // قسم الخدمات العامة
  WAREHOUSE            // المستودع
  TREASURY             // الصندوق
  ACCOUNTING           // المحاسبة
  ADMIN_COMMUNICATION  // وحدة الاتصالات الإدارية
  EMPLOYEE_AFFAIRS     // شؤون الموظفين
  SECURITY             // وحدة الأمن
  MAINTENANCE          // وحدة المرافق والصيانة
  HEALTH_SAFETY        // وحدة الصحة والسلامة
  CLINIC               // العيادة الطبية
  QUALITY_CONTROL_UNIT // وحدة ضبط الجودة
  SUPPORT_SERVICES     // إدارة الخدمات المساندة
  GIRLS_PRISON_DEPT    // قسم تدريب البنات بالسجون
}

enum DepartmentStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model Position {
  id           String   @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  code         String   // DEAN, VICE_DEAN, DEPT_HEAD, COORDINATOR, SECRETARY, AUDITOR, TRAINER, ACCOUNTANT, ...
  titleAr      String
  titleEn      String?
  rank         Int      @default(0)  // للترتيب الهرمي
  isManagerial Boolean  @default(false)
  budgetLimit  Decimal? @db.Decimal(15, 2) // سقف الاعتماد المالي (مثال 100,000 للعميد)
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments  Assignment[]

  @@unique([departmentId, code])
  @@map("positions")
}

model Assignment {
  id           String   @id @default(cuid())
  positionId   String
  departmentId String
  employeeId   String
  position     Position @relation(fields: [positionId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  employee     Employee @relation(fields: [employeeId], references: [id])
  isPrimary    Boolean  @default(true)
  isActing     Boolean  @default(false)  // مكلف بدلاً من
  validFrom    DateTime
  validUntil   DateTime?
  decisionRef  String?  // رقم قرار التكليف
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([departmentId])
  @@map("assignments")
}

// =====================================================================
// 4. HR — الموارد البشرية
// =====================================================================

model Employee {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String?  @unique
  user            User?    @relation(fields: [userId], references: [id])
  employeeNumber  String
  nationalId      String?
  fullNameAr      String
  fullNameEn      String?
  gender          Gender
  birthDate       DateTime?
  hireDate        DateTime
  contractType   ContractType @default(PERMANENT)
  jobTitleAr     String
  departmentId   String?
  department     Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  managedDepts   Department[] @relation("DepartmentManager")
  email          String?
  phone          String?
  status         EmployeeStatus @default(ACTIVE)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments    Assignment[]
  contracts      Contract[]
  leaves         Leave[]
  attendance     Attendance[]
  evaluations    Evaluation[]
  trainerProfile Trainer?

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@map("employees")
}

enum Gender {
  MALE
  FEMALE
}

enum ContractType {
  PERMANENT
  TEMPORARY
  CONTRACT
  VOLUNTEER
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RETIRED
  SECONDED
}

model Contract {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        ContractType
  startDate   DateTime
  endDate     DateTime?
  salary      Decimal? @db.Decimal(15, 2)
  documentUrl String?
  notes       String?
  createdAt   DateTime @default(now())

  @@map("contracts")
}

model Leave {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
  days         Int
  reason       String?
  status       LeaveStatus @default(PENDING)
  workflowInstanceId String? @unique
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  attachments  Attachment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId, status])
  @@map("leaves")
}

enum LeaveType {
  ANNUAL          // اعتيادية
  SICK            // مرضية
  EMERGENCY       // اضطرارية
  STUDY           // دراسية
  EXAM            // أداء اختبار
  POST_SECONDARY  // ما بعد الثانوي
  EXCEPTIONAL     // استثنائية
  MATERNITY       // أمومة
  UNPAID          // بدون راتب
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  delayMins   Int      @default(0)
  status      AttendanceStatus @default(PRESENT)
  source      AttendanceSource @default(BIOMETRIC)
  notes       String?
  createdAt   DateTime @default(now())

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  OFF
}

enum AttendanceSource {
  BIOMETRIC
  MANUAL
  MOBILE
}

model Evaluation {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period      String   // 2025-H1 ...
  score       Decimal  @db.Decimal(5, 2)
  rating      EvalRating
  evaluatorId String?
  comments    String?
  workflowInstanceId String? @unique
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  createdAt   DateTime @default(now())

  @@index([employeeId, period])
  @@map("evaluations")
}

enum EvalRating {
  OUTSTANDING
  EXCEEDS
  MEETS
  BELOW
  UNSATISFACTORY
}

// =====================================================================
// 5. COUNCIL — مجلس المنشأة والاجتماعات
// =====================================================================

model Council {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nameAr      String
  type        CouncilType
  termFrom    DateTime
  termUntil   DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())

  members     CouncilMember[]
  meetings    Meeting[]

  @@map("councils")
}

enum CouncilType {
  MAIN_COUNCIL    // مجلس المنشأة
  EXEC_COMMITTEE  // اللجنة التنفيذية
  WORK_COMMITTEE  // لجان العمل
}

model CouncilMember {
  id        String   @id @default(cuid())
  councilId String
  council   Council  @relation(fields: [councilId], references: [id], onDelete: Cascade)
  employeeId String?
  externalName String?
  role      String   // رئيس، أمين، عضو، عضو من خارج المؤسسة
  isInternal Boolean @default(true)
  validFrom DateTime
  validUntil DateTime?

  @@map("council_members")
}

model Meeting {
  id           String   @id @default(cuid())
  councilId    String?
  council      Council? @relation(fields: [councilId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  titleAr      String
  agenda       Json     // [{ item, presenter, durationMins }]
  scheduledAt  DateTime
  endedAt      DateTime?
  location     String?
  status       MeetingStatus @default(SCHEDULED)
  minutesUrl   String?  // رابط محضر PDF بعد التوقيع
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendees    MeetingAttendee[]
  decisions    Decision[]
  attachments  Attachment[]
  workflowInstanceId String? @unique
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])

  @@index([scheduledAt])
  @@map("meetings")
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model MeetingAttendee {
  id         String   @id @default(cuid())
  meetingId  String
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String?
  externalName String?
  status     AttendeeStatus @default(INVITED)
  joinedAt   DateTime?
  leftAt     DateTime?

  @@map("meeting_attendees")
}

enum AttendeeStatus {
  INVITED
  CONFIRMED
  PRESENT
  ABSENT
  EXCUSED
}

model Decision {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  number      String   // قرار رقم 12 / 1446
  topic       String
  description String
  vote        VoteResult @default(PENDING)
  approvedBy  Int      @default(0)
  rejectedBy  Int      @default(0)
  abstained   Int      @default(0)
  dueDate     DateTime?
  ownerId     String?  // من سيتولى التنفيذ
  status      DecisionStatus @default(OPEN)
  createdAt   DateTime @default(now())

  votes       Vote[]

  @@map("decisions")
}

enum VoteResult {
  PENDING
  APPROVED
  REJECTED
  DEFERRED
}

enum DecisionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model Vote {
  id          String   @id @default(cuid())
  decisionId  String
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  voterId     String
  voterRole   String?
  vote        VoteChoice
  reason      String?
  createdAt   DateTime @default(now())

  @@unique([decisionId, voterId])
  @@map("votes")
}

enum VoteChoice {
  APPROVE
  REJECT
  ABSTAIN
}

// =====================================================================
// 6. FINANCE — الشؤون المالية
// =====================================================================

model Budget {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  fiscalYear   String   // 1446
  category     String   // عمليات، مشتريات، صيانة، تأمين، إلخ
  allocated    Decimal  @db.Decimal(15, 2)
  spent        Decimal  @db.Decimal(15, 2) @default(0)
  reserved     Decimal  @db.Decimal(15, 2) @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseRequests PurchaseRequest[]

  @@unique([tenantId, departmentId, fiscalYear, category])
  @@map("budgets")
}

model PurchaseRequest {
  id           String   @id @default(cuid())
  number       String   @unique // PR-1446-001
  requesterId  String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  budgetId     String?
  budget       Budget?  @relation(fields: [budgetId], references: [id])
  type         PurchaseType
  description  String
  amount       Decimal  @db.Decimal(15, 2)
  currency     String   @default("SAR")
  status       PRStatus @default(DRAFT)
  workflowInstanceId String? @unique
  workflowInstance WorkflowInstance? @relation(fields: [workflowInstanceId], references: [id])
  vendorName   String?
  expectedDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PurchaseItem[]
  invoices     Invoice[]
  attachments  Attachment[]

  @@index([departmentId, status])
  @@map("purchase_requests")
}

enum PurchaseType {
  EQUIPMENT
  TRAINING_NEEDS
  MAINTENANCE
  INSURANCE
  COMMUNITY_CENTER
  OTHER
}

enum PRStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
  CANCELLED
}

model PurchaseItem {
  id        String   @id @default(cuid())
  prId      String
  pr        PurchaseRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  nameAr    String
  qty       Decimal  @db.Decimal(10, 2)
  unit      String?
  unitPrice Decimal  @db.Decimal(15, 2)
  total     Decimal  @db.Decimal(15, 2)

  @@map("purchase_items")
}

model Invoice {
  id          String   @id @default(cuid())
  prId        String?
  pr          PurchaseRequest? @relation(fields: [prId], references: [id])
  number      String   @unique
  vendorName  String
  amount      Decimal  @db.Decimal(15, 2)
  vat         Decimal  @db.Decimal(15, 2) @default(0)
  total       Decimal  @db.Decimal(15, 2)
  dueDate     DateTime?
  paidAt      DateTime?
  status      InvoiceStatus @default(PENDING)
  attachments Attachment[]
  createdAt   DateTime @default(now())

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  APPROVED
  PAID
  OVERDUE
  CANCELLED
}

// =====================================================================
// 7. TRAINEES — شؤون المتدربين
// =====================================================================

model Trainee {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  studentNumber String
  nationalId    String?
  fullNameAr    String
  fullNameEn    String?
  gender        Gender
  birthDate     DateTime?
  enrollmentDate DateTime
  programId     String?
  program       Program? @relation(fields: [programId], references: [id])
