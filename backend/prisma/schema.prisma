  fundingAmount Decimal? @db.Decimal(15, 2)
  fundingSource String?
  startDate   DateTime?
  endDate     DateTime?
  outcomeUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

