  activities    Json     // [{ ar, ownerEmpId, startDate, endDate, status }]
  status        PlanStatus @default(DRAFT)
  createdById   String
  approvedAt    DateTime?
  workflowInstanceId String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, fiscalYear, scope, season])
  @@map("quality_plans")
}

enum QualityPlanScope {
  SEASONAL
  YEARLY
}

model QualityTeam {
  id              String   @id @default(cuid())
  tenantId        String
  nameAr          String
  charter         Json     // { purposeAr, scopeAr, deliverables, deadline, sponsorEmpId }
  leadEmpId       String?
  members         Json     // [{ empId, role, joinedAt }]
  status          TeamStatus @default(PROPOSED)
  workflowInstanceId String? @unique
